datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     String @default("USER")
}

model Vehicle {
  id       Int    @id @default(autoincrement())
  make     String
  model    String
  category String
  price    Float
  quantity Int    @default(0)
}
